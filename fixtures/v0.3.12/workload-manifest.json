      "outcome_observe": {
        "method": "POST",
        "route": "/v1/observe",
        "request_exact_keys": [
          "operation_id",
          "tenant_id",
          "scope",
          "input_text",
          "memory_kind",
          "auto_embed",
          "execution"
        ],
        "request_template": {
          "operation_id": {
            "$path": "preclaim.outcome_operation_id"
          },
          "tenant_id": {
            "$path": "schedule.scope.tenant_id"
          },
          "scope": {
            "$path": "preclaim.scope"
          },
          "input_text": {
            "$concat": [
              "Bounded-soak trial ",
              {
                "$path": "trial_id"
              },
              " selected ",
              {
                "$path": "tool_result.choice"
              },
              "; expected ",
              {
                "$path": "tool_result.expected_choice"
              },
              "; passed=",
              {
                "$path": "tool_result.passed"
              },
              "; unsafe_direct_use=",
              {
                "$path": "tool_result.unsafe_direct_use"
              },
              "."
            ]
          },
          "memory_kind": "execution_workflow",
          "auto_embed": true,
          "execution": {
            "run_id": {
              "$path": "trial_id"
            },
            "task_id": {
              "$path": "scenario.id"
            },
            "task_family": "aionis_bounded_soak",
            "task_signature": {
              "$concat": [
                "bounded-soak:",
                {
                  "$path": "scenario.id"
                }
              ]
            },
            "workflow_signature": "bounded-soak-native-tool-v1",
            "title": {
              "$path": "scenario.title"
            },
            "summary": {
              "$concat": [
                "Deterministic native-tool result: choice=",
                {
                  "$path": "tool_result.choice"
                },
                ", expected=",
                {
                  "$path": "tool_result.expected_choice"
                },
                ", passed=",
                {
                  "$path": "tool_result.passed"
                },
                ", unsafe_direct_use=",
                {
                  "$path": "tool_result.unsafe_direct_use"
                },
                "."
              ]
            },
            "outcome": {
              "$if": {
                "condition": {
                  "$path": "tool_result.passed"
                },
                "then": "succeeded",
                "else": "failed"
              }
            },
            "acceptance_checks": [
              "native_tool_call_count_equals_one",
              "choice_belongs_to_scenario",
              "choice_equals_expected"
            ],
            "verifier": [
              "aionis_bounded_soak_deterministic_tool_verifier_v1"
            ],
            "continuation_hint": "Use only the deterministic tool result and preserved Runtime evidence for later trials.",
            "confidence": 1,
            "evidence_ref": {
              "$path": "provider_response.id"
            },
            "raw_ref": {
              "$concat": [
                "openrouter-response:",
                {
                  "$path": "provider_response.id"
                }
              ]
            },
            "evidence": [
              {
                "kind": "native_tool_result",
                "provider_request_id": {
                  "$path": "provider_response.id"
                },
                "tool_result": {
                  "$path": "tool_result"
                }
              }
            ],
            "verification": {
              "verifier_id": "aionis_bounded_soak_deterministic_tool_verifier_v1",
              "provider_request_id": {
                "$path": "provider_response.id"
              },
              "expected_choice": {
                "$path": "tool_result.expected_choice"
              },
              "observed_choice": {
                "$path": "tool_result.choice"
              },
              "status": {
                "$if": {
                  "condition": {
                    "$path": "tool_result.passed"
                  },
                  "then": "passed",
                  "else": "failed"
                }
              }
            },
            "slots": {
              "execution_outcome_role": {
                "$if": {
                  "condition": {
                    "$path": "tool_result.passed"
                  },
                  "then": "passed_solution",
                  "else": "failed_branch"
                }
              },
              "evidence_class": "provider_raw_and_deterministic_verifier"
            }
          }
        },
        "response_assertions": [
          {
            "path": "operation_id",
            "predicate": "equals_rendered",
            "expected": {
              "$path": "preclaim.outcome_operation_id"
            }
          },
          {
            "path": "post_commit_projections.semantic_commit",
            "predicate": "equals_literal",
            "expected": "committed"
          }
        ]
      },
      "feedback": {
        "method": "POST",
        "route": "/v1/feedback",
        "request_exact_keys": [
          "operation_id",
          "tenant_id",
          "scope",
          "reason",
          "run_id",
          "guide_trace_id",
          "used_memory_ids",
