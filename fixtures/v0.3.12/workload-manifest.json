            "$path": "guide_response.guide_trace_id"
          },
          "used_memory_ids": {
            "$path": "served_memory_selection.ids"
          },
          "outcome": {
            "$if": {
              "condition": {
                "$equals": [
                  {
                    "$path": "served_memory_selection.surface"
                  },
                  "use_now"
                ]
              },
              "then": {
                "$if": {
                  "condition": {
                    "$path": "tool_result.passed"
                  },
                  "then": "positive",
                  "else": "negative"
                }
              },
              "else": "neutral"
            }
          },
          "used_surface": {
            "$path": "served_memory_selection.surface"
          },
          "verifier_status": {
            "$if": {
              "condition": {
                "$path": "tool_result.passed"
              },
              "then": "passed",
              "else": "failed"
            }
          },
          "tool_status": "succeeded",
          "runtime_signal_refs": [
            {
              "$concat": [
                "provider:",
                {
                  "$path": "provider_response.id"
                }
              ]
            },
            {
              "$concat": [
                "outcome:",
                {
                  "$path": "preclaim.outcome_operation_id"
                }
              ]
            }
          ]
        },
