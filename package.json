{
  "name": "aionis-continuation-runtime-evals",
  "version": "1.0.0-alpha.1",
  "private": true,
  "description": "Exact, evidence-bound external evaluation for Aionis Continuation Runtime V1.",
  "license": "Apache-2.0",
  "type": "module",
  "engines": {
    "node": ">=22.15.0 <23 || >=24.0.0 <25"
  },
  "scripts": {
    "check": "npm run -s syntax:check && npm run -s test",
    "syntax:check": "node src/cli/check-source.mjs",
    "test": "node --test test/*.test.mjs",
    "test:runtime-v1": "node --test test/runtime-v1.integration.mjs",
    "provider:smoke": "node src/cli/smoke-deepseek-provider.mjs",
    "pilot:freeze-release": "node src/cli/freeze-release-pilot.mjs",
    "pilot:preflight": "node src/cli/preflight-pilot.mjs",
    "pilot:recover-release": "node src/cli/recover-release-pilot.mjs",
    "pilot:run-release": "node src/cli/run-release-pilot.mjs"
  }
}
