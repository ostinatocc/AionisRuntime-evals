{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/ostinatocc/AionisRuntime-evals/schemas/workflow-run-evidence.schema.json",
  "title": "Sanitized GitHub workflow run evidence",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "repository",
    "fetched_at",
    "records",
    "release",
    "artifacts",
    "assets"
  ],
  "properties": {
    "schema_version": {
      "const": "aionis_workflow_run_evidence_v1"
    },
    "repository": {
      "const": "ostinatocc/AionisRuntime-evals"
    },
    "fetched_at": {
      "type": "string",
      "format": "date-time"
    },
    "records": {
      "type": "array",
      "minItems": 3,
      "maxItems": 3,
      "items": {
        "$ref": "#/$defs/record"
      }
    },
    "release": {
      "$ref": "#/$defs/release"
    },
    "artifacts": {
      "type": "array",
      "minItems": 6,
      "maxItems": 6,
      "items": {
        "$ref": "#/$defs/artifact"
      }
    },
    "assets": {
      "type": "array",
      "minItems": 6,
      "maxItems": 6,
      "items": {
        "$ref": "#/$defs/asset"
      }
    }
  },
  "$defs": {
    "release": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "tag_name",
        "target_commitish",
        "draft",
        "prerelease",
        "immutable",
        "created_at",
        "published_at",
        "author"
      ],
      "properties": {
        "id": {
          "type": "integer",
          "minimum": 1
        },
        "tag_name": {
          "type": "string",
          "pattern": "^soak-v[0-9]+\\.[0-9]+\\.[0-9]+-[a-f0-9]{40}$"
        },
        "target_commitish": {
          "type": "string",
          "pattern": "^[a-f0-9]{40}$"
        },
        "draft": {
          "const": false
        },
        "prerelease": {
          "const": true
        },
        "immutable": {
          "const": true
        },
        "created_at": {
          "type": "string",
          "format": "date-time"
        },
        "published_at": {
          "type": "string",
          "format": "date-time"
        },
        "author": {
          "const": "github-actions[bot]"
        }
      }
    },
    "artifact": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "name",
        "size_in_bytes",
        "digest",
        "expired",
        "created_at",
        "updated_at",
        "expires_at",
        "workflow_run_id",
        "workflow_run_head_sha"
      ],
      "properties": {
        "id": {
          "type": "integer",
          "minimum": 1
        },
        "name": {
          "type": "string",
          "pattern": "^soak-[0-9a-z_]+-[a-f0-9]{40}-[1-9][0-9]*-[1-9][0-9]*-[a-f0-9]{64}$"
        },
        "size_in_bytes": {
          "type": "integer",
          "minimum": 1
        },
        "digest": {
          "type": "string",
          "pattern": "^sha256:[a-f0-9]{64}$"
        },
        "expired": {
          "const": false
        },
        "created_at": {
          "type": "string",
          "format": "date-time"
        },
        "updated_at": {
          "type": "string",
          "format": "date-time"
        },
        "expires_at": {
          "type": "string",
          "format": "date-time"
        },
        "workflow_run_id": {
          "type": "integer",
          "minimum": 1
        },
        "workflow_run_head_sha": {
          "type": "string",
          "pattern": "^[a-f0-9]{40}$"
        }
      }
    },
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "repository",
        "run_id",
        "run_attempt",
        "head_sha",
        "phase",
        "job",
        "environment"
      ],
      "properties": {
        "repository": {
          "const": "ostinatocc/AionisRuntime-evals"
        },
        "run_id": {
          "type": "integer",
          "minimum": 1
        },
        "run_attempt": {
          "type": "integer",
          "minimum": 1
        },
        "head_sha": {
          "type": "string",
          "pattern": "^[a-f0-9]{40}$"
        },
        "phase": {
          "enum": [
            "pilot",
            "soak",
            "publisher"
          ]
        },
        "job": {
          "enum": [
            "paid-preflight",
            "evidence-publisher"
          ]
        },
        "environment": {
          "enum": [
            "bounded-soak",
            "bounded-soak-publisher"
          ]
        }
      }
    },
    "run": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "run_attempt",
        "event",
        "status",
        "conclusion",
        "head_sha",
        "repository",
        "path",
        "created_at",
        "updated_at"
      ],
      "properties": {
        "id": {
          "type": "integer",
          "minimum": 1
        },
        "run_attempt": {
          "type": "integer",
          "minimum": 1
        },
        "event": {
          "const": "workflow_dispatch"
        },
        "status": {
          "const": "completed"
        },
        "conclusion": {
          "const": "success"
        },
        "head_sha": {
          "type": "string",
          "pattern": "^[a-f0-9]{40}$"
        },
        "repository": {
          "const": "ostinatocc/AionisRuntime-evals"
        },
        "path": {
          "type": "string",
          "pattern": "^\\.github/workflows/bounded-soak\\.yml(?:@[A-Za-z0-9._/-]+)?$"
        },
        "created_at": {
          "type": "string",
          "format": "date-time"
        },
        "updated_at": {
          "type": "string",
          "format": "date-time"
        }
      }
    },
    "job": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "run_id",
        "run_attempt",
        "head_sha",
        "name",
        "status",
        "conclusion",
        "labels",
        "runner_id",
        "runner_group_name",
        "started_at",
        "completed_at"
      ],
      "properties": {
        "id": {
          "type": "integer",
          "minimum": 1
        },
        "run_id": {
          "type": "integer",
          "minimum": 1
        },
        "run_attempt": {
          "type": "integer",
          "minimum": 1
        },
        "head_sha": {
          "type": "string",
          "pattern": "^[a-f0-9]{40}$"
        },
        "name": {
          "enum": [
            "Protected pilot preflight",
            "Protected soak preflight",
            "Protected evidence publisher"
          ]
        },
        "status": {
          "const": "completed"
        },
        "conclusion": {
          "const": "success"
        },
        "labels": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "runner_id": {
          "type": "integer",
          "minimum": 1
        },
        "runner_group_name": {
          "type": [
            "string",
            "null"
          ]
        },
        "started_at": {
          "type": "string",
          "format": "date-time"
        },
        "completed_at": {
          "type": "string",
          "format": "date-time"
        }
      }
    },
    "asset": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "name",
        "size",
        "digest",
        "state",
        "created_at",
        "updated_at",
        "uploader",
        "download_url"
      ],
      "properties": {
        "id": {
          "type": "integer",
          "minimum": 1
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "size": {
          "type": "integer",
          "minimum": 1,
          "maximum": 8388608
        },
        "digest": {
          "type": "string",
          "pattern": "^sha256:[a-f0-9]{64}$"
        },
        "state": {
          "const": "uploaded"
        },
        "created_at": {
          "type": "string",
          "format": "date-time"
        },
        "updated_at": {
          "type": "string",
          "format": "date-time"
        },
        "uploader": {
          "const": "github-actions[bot]"
        },
        "download_url": {
          "type": "string",
          "pattern": "^https://github\\.com/ostinatocc/AionisRuntime-evals/releases/download/[0-9A-Za-z._-]+/[0-9A-Za-z._-]+\\.jsonl$"
        }
      }
    },
    "record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "source",
        "run",
        "job"
      ],
      "properties": {
        "source": {
          "$ref": "#/$defs/source"
        },
        "run": {
          "$ref": "#/$defs/run"
        },
        "job": {
          "$ref": "#/$defs/job"
        }
      }
    }
  }
}
