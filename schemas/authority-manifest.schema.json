{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/ostinatocc/AionisRuntime-evals/schemas/authority-manifest.schema.json",
  "title": "Aionis bounded soak authority manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "authorized_at",
    "publication_authority",
    "candidate",
    "candidate_publication_receipt",
    "providers",
    "generation",
    "retry_policy",
    "execution_limits",
    "execution_authorization"
  ],
  "properties": {
    "schema_version": {
      "const": "aionis_soak_authority_manifest_v1"
    },
    "authorized_at": {
      "type": "string",
      "format": "date-time"
    },
    "publication_authority": {
      "const": false
    },
    "candidate": {
      "$ref": "#/$defs/candidate"
    },
    "candidate_publication_receipt": {
      "$ref": "#/$defs/receipt"
    },
    "providers": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "embedding",
        "agent"
      ],
      "properties": {
        "embedding": {
          "$ref": "#/$defs/embedding"
        },
        "agent": {
          "$ref": "#/$defs/agent"
        }
      }
    },
    "generation": {
      "$ref": "#/$defs/generation"
    },
    "retry_policy": {
      "$ref": "#/$defs/retryPolicy"
    },
    "execution_limits": {
      "$ref": "#/$defs/executionLimits"
    },
    "execution_authorization": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "mode",
        "environment",
        "paid_execution_default"
      ],
      "properties": {
        "mode": {
          "const": "protected_environment"
        },
        "environment": {
          "const": "bounded-soak"
        },
        "paid_execution_default": {
          "const": false
        }
      }
    }
  },
  "$defs": {
    "sha256": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    },
    "digest": {
      "type": "string",
      "pattern": "^sha256:[a-f0-9]{64}$"
    },
    "commit": {
      "type": "string",
      "pattern": "^[a-f0-9]{40}$"
    },
    "receipt": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "path",
        "sha256"
      ],
      "properties": {
        "path": {
          "type": "string",
          "pattern": "^docs/releases/[0-9A-Za-z._-]+\\.json$"
        },
        "sha256": {
          "$ref": "#/$defs/sha256"
        }
      }
    },
    "candidate": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "repository",
        "version",
        "tag",
        "commit",
        "image",
        "digest",
        "platform",
        "oci_revision",
        "oci_version"
      ],
      "properties": {
        "repository": {
          "type": "string",
          "pattern": "^https://github\\.com/[0-9A-Za-z_.-]+/[0-9A-Za-z_.-]+$"
        },
        "version": {
          "type": "string",
          "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
        },
        "tag": {
          "type": "string",
          "pattern": "^v[0-9]+\\.[0-9]+\\.[0-9]+$"
        },
        "commit": {
          "$ref": "#/$defs/commit"
        },
        "image": {
          "type": "string",
          "pattern": "^ghcr\\.io/[0-9A-Za-z_.-]+/[0-9A-Za-z_.-]+$"
        },
        "digest": {
          "$ref": "#/$defs/digest"
        },
        "platform": {
          "const": "linux/amd64"
        },
        "oci_revision": {
          "$ref": "#/$defs/commit"
        },
        "oci_version": {
          "type": "string",
          "pattern": "^v[0-9]+\\.[0-9]+\\.[0-9]+$"
        }
      }
    },
    "embedding": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "provider",
        "model",
        "persisted_model",
        "dimensions"
      ],
      "properties": {
        "provider": {
          "type": "string",
          "minLength": 1
        },
        "model": {
          "type": "string",
          "minLength": 1
        },
        "persisted_model": {
          "type": "string",
          "minLength": 1
        },
        "dimensions": {
          "type": "integer",
          "minimum": 1
        }
      }
    },
    "agent": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "provider",
        "requested_model",
        "allowed_returned_models",
        "fallback_allowed"
      ],
      "properties": {
        "provider": {
          "type": "string",
          "minLength": 1
        },
        "requested_model": {
          "type": "string",
          "minLength": 1
        },
        "allowed_returned_models": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "fallback_allowed": {
          "const": false
        }
      }
    },
    "generation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "temperature",
        "top_p",
        "max_output_tokens",
        "request_timeout_ms"
      ],
      "properties": {
        "temperature": {
          "type": "number",
          "minimum": 0
        },
        "top_p": {
          "type": "number",
          "exclusiveMinimum": 0,
          "maximum": 1
        },
        "max_output_tokens": {
          "type": "integer",
          "minimum": 1
        },
        "request_timeout_ms": {
          "type": "integer",
          "minimum": 1
        }
      }
    },
    "retryPolicy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "transport_max_attempts",
        "retryable_http_statuses",
        "retryable_network_codes",
        "semantic_retries"
      ],
      "properties": {
        "transport_max_attempts": {
          "type": "integer",
          "minimum": 1
        },
        "retryable_http_statuses": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "integer",
            "minimum": 400,
            "maximum": 599
          }
        },
        "retryable_network_codes": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "semantic_retries": {
          "const": 0
        }
      }
    },
    "executionLimits": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "minimum_duration_seconds",
        "maximum_duration_seconds",
        "maximum_chat_calls",
        "maximum_cost_usd",
        "pilot_chat_calls",
        "soak_chat_calls",
        "soak_waves",
        "persistent_volume_required"
      ],
      "properties": {
        "minimum_duration_seconds": {
          "type": "integer",
          "minimum": 1
        },
        "maximum_duration_seconds": {
          "type": "integer",
          "minimum": 1
        },
        "maximum_chat_calls": {
          "type": "integer",
          "minimum": 1
        },
        "maximum_cost_usd": {
          "type": "number",
          "exclusiveMinimum": 0
        },
        "pilot_chat_calls": {
          "type": "integer",
          "minimum": 1
        },
        "soak_chat_calls": {
          "type": "integer",
          "minimum": 1
        },
        "soak_waves": {
          "type": "integer",
          "minimum": 1
        },
        "persistent_volume_required": {
          "const": true
        }
      }
    }
  }
}

